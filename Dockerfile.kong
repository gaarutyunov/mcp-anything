FROM golang:1.25-alpine AS builder

RUN apk add --no-cache ca-certificates

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /mcp-anything-kong ./cmd/kong

FROM kong:3.9-ubuntu

USER root
RUN mkdir -p /etc/mcp-anything /etc/kong
COPY --from=builder /mcp-anything-kong /usr/local/bin/mcp-anything-kong

ENV KONG_PLUGINS=bundled,mcp-anything
ENV KONG_PLUGINSERVER_NAMES=mcp-anything
ENV KONG_PLUGINSERVER_MCP_ANYTHING_START_CMD=/usr/local/bin/mcp-anything-kong
ENV KONG_PLUGINSERVER_MCP_ANYTHING_QUERY_CMD="/usr/local/bin/mcp-anything-kong --dump"
ENV KONG_DATABASE=off
ENV KONG_DECLARATIVE_CONFIG=/etc/kong/kong.yaml
ENV KONG_ADMIN_LISTEN=0.0.0.0:8001
ENV KONG_PROXY_LISTEN=0.0.0.0:8000

EXPOSE 8000 8001
USER kong
